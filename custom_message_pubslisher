##Python code to publish a custom message
import rclpy
from rclpy.node import Node
from std_msgs.msg import String

class publisher(Node):
    def __init__(self):
        super().__init__("publisher")
        self.publishing=self.create_publisher(String,"publisher",10)
        self.timer=self.create_timer(0.6,self.publisher_callback)
        self.a=0
        
    def publisher_callback(self):
        msg = String()
        msg.data = "Published Message " + str(self.a)
        self.get_logger().info("Published Meassage"+" "+str(self.a))
        self.publishing.publish(msg)
        self.a+=1
def main(args=None):
    rclpy.init(args=args)
    var=publisher()
    rclpy.spin(var)
    rclpy.shutdown()
    
if __name__ == "__main__":
    main()
