#Python code for subscribing to terminal talker

import rclpy
from rclpy.node import Node
from std_msgs.msg import String

class talker_subscriber(Node):
    def __init__(self):
        super().__init__("Loop_Controller")
        self.subscribing=self.create_subscription(String,"/chatter",self.talker_callback,10)

    def talker_callback(self,clbck:String):
        self.get_logger().info(f"Published meassage : {clbck.data}")

def main(args=None):
    rclpy.init(args=args)
    node= talker_subscriber()
    rclpy.spin(node)
    rclpy.shutdown()

if __name__ == '__main__':
    main()
